# ── Required ─────────────────────────────────────────────────────────────
AMAZON_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AMAZON_CLIENT_SECRET=your-lwa-client-secret-here
AMAZON_REFRESH_TOKEN=Atzr|...
AMAZON_PROFILE_ID=1234567890123456

# ── Optional tweaks ──────────────────────────────────────────────────────
AMAZON_ACCOUNT_MODE=FIXED
UPSTREAM_URL=https://advertising-ai-eu.amazon.com/mcp
LWA_TOKEN_URL=https://api.amazon.com/auth/o2/token
REFRESH_LEAD_SECONDS=120

# ── Scripting helper (OFF by default) ────────────────────────────────────
# If true, GET http://localhost:PORT/access-token returns the current
# Bearer token as JSON. Useful for local Python scripts that need to call
# Amazon Ads APIs not covered by the MCP surface. No auth on the endpoint,
# so ONLY turn this on when the proxy is reachable on localhost / a
# trusted network. When false, the route does not exist (404).
EXPOSE_ACCESS_TOKEN=false

# ── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=9090
LOG_LEVEL=INFO
